# =============================================
# mcp-img-to-json — configuration (PER USER)
# L'utilisateur ne fournit JAMAIS de clé Google.
# Il achète des crédits sur le site, crée une clé API
# personnelle (nb_live_...) et la colle ici.
# La génération tourne côté serveur avec la clé Google
# du service => l'user consomme seulement ses crédits.
# =============================================

# Clé API personnelle de l'utilisateur (obligatoire).
# Créée sur le site : Profil → API → "Créer une clé". Format: nb_live_xxxxxxxx
IMG2JSON_API_KEY=nb_live_YOUR_KEY

# Base des Edge Functions du site (obligatoire).
# Ex Supabase : https://YOUR_PROJECT.supabase.co/functions/v1
IMG2JSON_API_BASE=https://YOUR_PROJECT.supabase.co/functions/v1

# Dossier où sauvegarder les images générées (optionnel, défaut: ./img2json-output)
IMG2JSON_OUT_DIR=
