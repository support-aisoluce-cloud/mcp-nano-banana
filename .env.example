# =============================================
# mcp-nano-banana — configuration (PER USER)
# The user NEVER provides a Google key.
# They buy credits on the site, create a personal
# API key (nb_live_...) and paste it here.
# Generation runs server-side with the service's
# Google key => the user only consumes their credits.
# =============================================

# The user's personal API key (required).
# Created on the site: Profile → API → "Create a key". Format: nb_live_xxxxxxxx
NANOBANANA_API_KEY=nb_live_YOUR_KEY

# Base of the site's Edge Functions (required).
# Supabase e.g.: https://YOUR_PROJECT.supabase.co/functions/v1
NANOBANANA_API_BASE=https://YOUR_PROJECT.supabase.co/functions/v1

# Folder where generated images are saved (optional, default: ./nano-banana-output)
NANOBANANA_OUT_DIR=
